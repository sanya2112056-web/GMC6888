# ── HTTP ──────────────────────────────────────────────────────
async def _get(url, params=None):
    try:
        async with httpx.AsyncClient(timeout=8) as c:
            r = await c.get(url, params=params)
            r.raise_for_status()
            return r.json()
    except Exception as e:
        log.debug(f"GET {url}: {e}")
        return None


